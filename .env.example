# ── Incident Airlock Graph Configuration ──────────────────────────────────────
# Copy this file to .env and update values as needed.

# AI Backend: "ollama" (default), "openai", or "none"
AIRLOCK_AI_BACKEND=ollama

# Ollama Settings (for local LLM inference)
AIRLOCK_OLLAMA_URL=http://localhost:11434/api/generate
AIRLOCK_OLLAMA_MODEL=llama3
AIRLOCK_OLLAMA_TIMEOUT=120

# OpenAI Settings (if using OpenAI backend)
AIRLOCK_OPENAI_API_KEY=
AIRLOCK_OPENAI_MODEL=gpt-4o-mini
AIRLOCK_OPENAI_TIMEOUT=60

# Data Directory
AIRLOCK_DATA_DIR=./data

# Engine Settings
AIRLOCK_CHANGE_CORRELATION_WINDOW_HOURS=48
AIRLOCK_MAX_MATCH_RESULTS=10
AIRLOCK_MIN_RELEVANCE_SCORE=0.1

# Debug Mode
AIRLOCK_DEBUG=false
